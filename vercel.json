{
  "version": 2,
  "routes": [
    {
      "src": "/install.sh",
      "headers": { "Content-Type": "text/plain; charset=utf-8" },
      "dest": "/install.sh"
    },
    {
      "src": "/install.ps1",
      "headers": { "Content-Type": "text/plain; charset=utf-8" },
      "dest": "/install.ps1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
